    "css": ".app {\n  height: calc(var(--appsmith-ui-height) * 1px);\n  width: calc(var(--appsmith-ui-width) * 1px);\n  justify-content: center;\n  border-radius: var(--appsmith-theme-borderRadius);\n  box-shadow: var(--appsmith-theme-boxShadow);\n  padding: 29px 25px;\n  box-sizing: border-box;\n  font-family: system-ui;\n  background: #fff;\n}\n\n.tip-container {\n  margin-bottom: 20px;\n  font-size: 14px;\n  line-height: 1.571429;\n}\n\n.tip-container h2 {\n  margin-bottom: 20px;\n  font-size: 16px;\n  font-weight: 700;\n}\n\n.tip-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: baseline;\n  margin-bottom: 9px;\n}\n\n.tip-header div {\n  color: #999;\n}\n\n.content {\n  white-space: pre-wrap;\n  word-break: break-word;\n  font-size: 14px;\n  line-height: 1.571429;\n}\n\n.button-container {\n  text-align: right;\n  padding-top: 4px;\n}\n\n.button-container button {\n  margin: 0 10px;\n  cursor: pointer;\n  border-radius: var(--appsmith-theme-borderRadius);\n  padding: 6px 16px;\n  background: none;\n  height: auto;\n  transition: all 0.3s ease;\n}\n\n.button-container button.primary {\n  background: var(--appsmith-theme-primaryColor) !important;\n  color: #fff;\n  border: 1px solid var(--appsmith-theme-primaryColor) !important;\n}\n\n.button-container button.reset {\n  border: 1px solid #999;\n  color: #999;\n  outline: none;\n  box-shadow: none;\n}\n\n.button-container button.reset:hover:not(:disabled) {\n  color: var(--appsmith-theme-primaryColor);\n  border-color: var(--appsmith-theme-primaryColor);\n}\n\n.button-container button.reset:disabled {\n  cursor: default;\n}",
    "html": "<div id=\"receipt-root\"></div>\n<button class=\"print-button\" onclick=\"window.print()\">Print / Ispis</button>\n\n<script>\n  function money(value) {\n    return Number(value || 0).toFixed(2);\n  }\n\n  function text(value) {\n    return value || \"\";\n  }\n\n  function companyLogoSrc(header = {}) {\n    return text(header.companyLogoPath || header.company_logo_path || header.CompanyLogoPath);\n  }\n\n  function fiscalQrPayload(header = {}) {\n    if (header.fiscalVerificationUrl) {\n      return header.fiscalVerificationUrl;\n    }\n\n    return [\n      \"JIR=\" + text(header.jir),\n      \"ZKI=\" + text(header.zki),\n      \"DATE=\" + text(header.createdAt || header.documentDate),\n      \"TOTAL=\" + money(header.totalAmount),\n      \"OIB=\" + text(header.companyTaxNumber)\n    ].join(\"&\");\n  }\n\n  function qrSrc(header = {}) {\n    return \"https://api.qrserver.com/v1/create-qr-code/?size=180x180&ecc=L&margin=2&data=\"\n      + encodeURIComponent(fiscalQrPayload(header));\n  }\n\n  function renderReceipt(data = {}) {\n    const header = data.header || {};\n    const items = data.items || [];\n    const taxes = data.taxes || [];\n    const logoSrc = companyLogoSrc(header);\n\n    document.getElementById(\"receipt-root\").innerHTML = `\n      <div class=\"receipt-page\">\n        <section class=\"receipt-header\">\n          ${logoSrc ? `\n            <img class=\"company-logo\" src=\"${logoSrc}\" alt=\"Logo\">\n          ` : \"\"}\n\n          <div class=\"store-name\">${text(header.companyName)}</div>\n          <div class=\"store-line\">${text(header.companyAddress)}</div>\n          <div class=\"store-line\">${text(header.companyPostalCode)} ${text(header.companyCity)}</div>\n          <div class=\"store-line\">OIB/VAT: ${text(header.companyTaxNumber)}</div>\n          <div class=\"store-line\">${text(header.companyPhone)}</div>\n        </section>\n\n        <div class=\"divider\"></div>\n\n        <section>\n          <div class=\"title\">RECEIPT / RAČUN</div>\n          <div class=\"kv\"><span>No / Broj</span><strong>${text(header.documentNumber)}</strong></div>\n          <div class=\"kv\"><span>Date / Datum</span><strong>${text(header.createdAt || header.documentDate)}</strong></div>\n          <div class=\"kv\"><span>Store / Poslovnica</span><strong>${text(header.warehouseName || header.warehouseCode)}</strong></div>\n          <div class=\"kv\"><span>Cashier / Blagajnik</span><strong>${text(header.cashier || header.createdBy)}</strong></div>\n        </section>\n\n        <div class=\"divider\"></div>\n\n        <section class=\"items\">\n          ${items.map(row => `\n            <div class=\"item\">\n              <div class=\"item-name\">${text(row.description)}</div>\n              <div class=\"item-code\">${text(row.productCode)} ${row.barcode ? \" / \" + text(row.barcode) : \"\"}</div>\n              <div class=\"item-line\">\n                <span>${money(row.quantity)} ${text(row.unitName)} x ${money(row.unitPrice)}</span>\n                <strong>${money(row.lineTotal)}</strong>\n              </div>\n              ${Number(row.discountAmount || 0) > 0 ? `\n                <div class=\"item-line muted\">\n                  <span>Discount / Popust</span>\n                  <span>-${money(row.discountAmount)}</span>\n                </div>\n              ` : \"\"}\n              <div class=\"item-line muted\">\n                <span>VAT / PDV ${money(row.taxRate)}%</span>\n                <span>${money(row.taxAmount)}</span>\n              </div>\n            </div>\n          `).join(\"\")}\n        </section>\n\n        <div class=\"divider\"></div>\n\n        <section class=\"totals\">\n          <div class=\"kv\"><span>Subtotal / Osnovica</span><strong>${money(header.subtotalAmount)}</strong></div>\n          <div class=\"kv\"><span>Discount / Popust</span><strong>${money(header.discountAmount)}</strong></div>\n          <div class=\"kv\"><span>VAT / PDV</span><strong>${money(header.taxAmount)}</strong></div>\n          <div class=\"grand-total\">\n            <span>TOTAL / UKUPNO</span>\n            <strong>${money(header.totalAmount)} ${text(header.currencyCode)}</strong>\n          </div>\n          <div class=\"kv\"><span>Payment / Plaćanje</span><strong>${text(header.paymentMethod)} ${header.cardType ? \"- \" + text(header.cardType) : \"\"}</strong></div>\n          <div class=\"kv\"><span>Paid / Plaćeno</span><strong>${money(header.paidAmount)} ${text(header.currencyCode)}</strong></div>\n        </section>\n\n        <div class=\"divider\"></div>\n\n        <section class=\"tax-summary\">\n          <div class=\"section-title\">VAT summary / Rekapitulacija PDV-a</div>\n          ${taxes.map(row => `\n            <div class=\"kv\">\n              <span>${money(row.taxRate)}%</span>\n              <strong>${money(row.taxableAmount)} + ${money(row.taxAmount)}</strong>\n            </div>\n          `).join(\"\")}\n        </section>\n\n        <div class=\"divider\"></div>\n\n        <section class=\"fiscal\">\n          <div class=\"fiscal-title\">Fiscal verification / Fiskalna provjera</div>\n          <div>ZKI: ${text(header.zki) || \"-\"}</div>\n          <div>JIR: ${text(header.jir) || \"-\"}</div>\n          <div>Issue time / Vrijeme izdavanja:</div>\n          <div>${text(header.createdAt || header.documentDate)}</div>\n\n          <div class=\"qr-center\">\n            <img class=\"qr-code-pos\" src=\"${qrSrc(header)}\" alt=\"Fiscal QR Code\">\n            <div class=\"qr-label-pos\">Scan to verify / Skeniraj za provjeru</div>\n          </div>\n        </section>\n\n        <div class=\"divider\"></div>\n\n        <section class=\"legal\">\n          Electronic invoice valid without signature and stamp.<br>\n          Elektronički račun pravovaljan bez potpisa i pečata.\n        </section>\n\n        <div class=\"divider\"></div>\n\n        <section class=\"thanks\">\n          Thank you / Hvala\n        </section>\n      </div>\n    `;\n  }\n\n  function update(model) {\n    renderReceipt(model || {});\n  }\n\n  update(window.appsmith?.model || {});\n\n  if (window.appsmith?.onModelChange) {\n    window.appsmith.onModelChange(update);\n  }\n</script>\n\n<style>\n  body {\n    margin: 0;\n    background: #f3f4f6;\n    color: #111827;\n    font-family: Arial, sans-serif;\n  }\n\n  .receipt-page {\n    width: 80mm;\n    margin: 0 auto;\n    padding: 5mm;\n    background: white;\n    box-sizing: border-box;\n    font-size: 12px;\n    line-height: 1.35;\n  }\n\n  .receipt-header {\n    text-align: center;\n  }\n\n  .company-logo {\n    max-width: 52mm;\n    max-height: 22mm;\n    object-fit: contain;\n    display: block;\n    margin: 0 auto 6px auto;\n  }\n\n  .store-name {\n    font-size: 18px;\n    font-weight: 900;\n    text-transform: uppercase;\n    margin-bottom: 4px;\n  }\n\n  .store-line {\n    font-size: 10.5px;\n    color: #374151;\n  }\n\n  .divider {\n    border-top: 1px dashed #111827;\n    margin: 9px 0;\n  }\n\n  .title {\n    text-align: center;\n    font-size: 14px;\n    font-weight: 900;\n    margin-bottom: 8px;\n  }\n\n  .kv,\n  .item-line,\n  .grand-total {\n    display: flex;\n    justify-content: space-between;\n    gap: 8px;\n    align-items: baseline;\n  }\n\n  .kv {\n    margin: 3px 0;\n  }\n\n  .item {\n    margin-bottom: 9px;\n  }\n\n  .item-name {\n    font-weight: 800;\n  }\n\n  .item-code {\n    color: #6b7280;\n    font-size: 10px;\n  }\n\n  .muted {\n    color: #6b7280;\n    font-size: 10.5px;\n  }\n\n  .grand-total {\n    background: #111827;\n    color: white;\n    padding: 8px;\n    margin: 7px 0;\n    font-size: 14px;\n    font-weight: 900;\n  }\n\n  .section-title,\n  .fiscal-title {\n    font-weight: 900;\n    margin-bottom: 5px;\n  }\n\n  .fiscal {\n    font-size: 10px;\n    word-break: break-word;\n  }\n\n  .qr-center {\n    margin-top: 9px;\n    text-align: center;\n  }\n\n  .qr-code-pos {\n    width: 118px;\n    height: 118px;\n    display: inline-block;\n  }\n\n  .qr-label-pos {\n    margin-top: 4px;\n    font-size: 9px;\n    color: #6b7280;\n    font-weight: 700;\n  }\n\n  .legal {\n    text-align: center;\n    font-size: 10px;\n    line-height: 1.35;\n  }\n\n  .print-button {\n    display: block;\n    margin: 10px auto;\n    padding: 8px 14px;\n    background: #111827;\n    color: white;\n    border: none;\n    font-weight: 800;\n    cursor: pointer;\n  }\n\n  .thanks {\n    text-align: center;\n    font-weight: 900;\n    font-size: 13px;\n  }\n\n  @media print {\n    body {\n      background: white;\n    }\n\n    .receipt-page {\n      width: 80mm;\n      margin: 0;\n      padding: 4mm;\n    }\n\n    .print-button {\n      display: none;\n    }\n  }\n</style>\n",
