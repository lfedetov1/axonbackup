    "css": ".app {\n  height: calc(var(--appsmith-ui-height) * 1px);\n  width: calc(var(--appsmith-ui-width) * 1px);\n  justify-content: center;\n  border-radius: var(--appsmith-theme-borderRadius);\n  box-shadow: var(--appsmith-theme-boxShadow);\n  padding: 29px 25px;\n  box-sizing: border-box;\n  font-family: system-ui;\n  background: #fff;\n}\n\n.tip-container {\n  margin-bottom: 20px;\n  font-size: 14px;\n  line-height: 1.571429;\n}\n\n.tip-container h2 {\n  margin-bottom: 20px;\n  font-size: 16px;\n  font-weight: 700;\n}\n\n.tip-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: baseline;\n  margin-bottom: 9px;\n}\n\n.tip-header div {\n  color: #999;\n}\n\n.content {\n  white-space: pre-wrap;\n  word-break: break-word;\n  font-size: 14px;\n  line-height: 1.571429;\n}\n\n.button-container {\n  text-align: right;\n  padding-top: 4px;\n}\n\n.button-container button {\n  margin: 0 10px;\n  cursor: pointer;\n  border-radius: var(--appsmith-theme-borderRadius);\n  padding: 6px 16px;\n  background: none;\n  height: auto;\n  transition: all 0.3s ease;\n}\n\n.button-container button.primary {\n  background: var(--appsmith-theme-primaryColor) !important;\n  color: #fff;\n  border: 1px solid var(--appsmith-theme-primaryColor) !important;\n}\n\n.button-container button.reset {\n  border: 1px solid #999;\n  color: #999;\n  outline: none;\n  box-shadow: none;\n}\n\n.button-container button.reset:hover:not(:disabled) {\n  color: var(--appsmith-theme-primaryColor);\n  border-color: var(--appsmith-theme-primaryColor);\n}\n\n.button-container button.reset:disabled {\n  cursor: default;\n}",
    "html": "<button class=\"print-button\" onclick=\"window.print()\">Print / Ispis</button>\n<div id=\"report-root\"></div>\n\n<script>\n  function money(value) {\n    return Number(value || 0).toFixed(2);\n  }\n\n  function text(value) {\n    return value || \"\";\n  }\n\n  function companyLogoSrc(data = {}, d = {}) {\n    return text(d.companyLogoPath || d.company_logo_path || d.CompanyLogoPath || data.companyLogoPath || data.company_logo_path || data.CompanyLogoPath);\n  }\n\n  function nowText() {\n    return new Date().toLocaleString(\"hr-HR\");\n  }\n\n  function payload(data = {}) {\n    const d = data.data || {};\n    return [\n      \"TYPE=\" + text(data.type),\n      \"DATE=\" + text(d.reportDate || d.paymentDate || d.closingDate || nowText()),\n      \"REGISTER=\" + text(d.cashRegisterCode),\n      \"TOTAL=\" + money(d.totalSales || d.grandTotal || d.amount || d.cashDepositTotal)\n    ].join(\"&\");\n  }\n\n  function qrSrc(data = {}) {\n    return \"https://api.qrserver.com/v1/create-qr-code/?size=110x110&ecc=L&margin=1&data=\"\n      + encodeURIComponent(payload(data));\n  }\n\n  function line(label, value) {\n    return `\n      <div class=\"line\">\n        <span>${label}</span>\n        <strong>${value}</strong>\n      </div>\n    `;\n  }\n\n  function cashRows(rows = []) {\n    if (!rows.length) {\n      return \"\";\n    }\n\n    return `\n      <div class=\"divider\"></div>\n      <div class=\"section-title\">Cash Specification / Specifikacija gotovine</div>\n      ${rows.map(row => line(\n        `${text(row.Denomination)} x ${text(row.Quantity)}`,\n        money(row.Amount)\n      )).join(\"\")}\n    `;\n  }\n\n  function render(data = {}) {\n    const d = data.data || {};\n    const rows = data.cashRows || [];\n    const logoSrc = companyLogoSrc(data, d);\n\n    return `\n      <div class=\"report-page\">\n        <section class=\"header\">\n          ${logoSrc ? `\n            <img class=\"company-logo\" src=\"${logoSrc}\" alt=\"Logo\">\n          ` : \"\"}\n\n          <div class=\"brand\">${text(d.companyName || data.companyName || \"POS\")}</div>\n          <div class=\"small\">${text(d.warehouseName || d.storeName || \"\")}</div>\n          <div class=\"small\">Register / Blagajna: ${text(d.cashRegisterCode)}</div>\n        </section>\n\n        <div class=\"divider\"></div>\n\n        <section>\n          <div class=\"title\">${text(data.title)}</div>\n          ${line(\"Date / Datum\", text(d.reportDate || d.paymentDate || d.closingDate || nowText()))}\n          ${line(\"Cashier / Blagajnik\", text(d.cashier || d.username))}\n          ${line(\"Printed / Ispisano\", nowText())}\n        </section>\n\n        <div class=\"divider\"></div>\n\n        ${renderBody(data)}\n\n        ${cashRows(rows)}\n\n        <div class=\"divider\"></div>\n\n        <section class=\"qr-box\">\n          <img class=\"qr-small\" src=\"${qrSrc(data)}\" alt=\"QR Code\">\n          <div class=\"small\">Verification code / Kod provjere</div>\n        </section>\n\n        <div class=\"divider\"></div>\n\n        <section class=\"signatures\">\n          <div>Cashier signature / Potpis blagajnika</div>\n          <div class=\"signature-line\"></div>\n          <div>Manager signature / Potpis voditelja</div>\n          <div class=\"signature-line\"></div>\n        </section>\n      </div>\n    `;\n  }\n\n  function renderBody(data = {}) {\n    const d = data.data || {};\n\n    switch (data.type) {\n      case \"OPENING_BALANCE\":\n        return `\n          ${line(\"Opening amount / Početni polog\", money(d.openingAmount))}\n          ${line(\"Currency / Valuta\", text(d.currencyCode || \"EUR\"))}\n          ${line(\"Note / Napomena\", text(d.note))}\n        `;\n\n      case \"TOTAL_SALES\":\n        return `\n          ${line(\"Receipt count / Broj računa\", text(d.receiptCount))}\n          ${line(\"Cash / Gotovina\", money(d.cashTotal || d.cashRevenue))}\n          ${line(\"Card / Kartice\", money(d.cardTotal || d.cardRevenue))}\n          ${line(\"Other / Ostalo\", money(d.otherTotal || d.otherRevenue))}\n          ${line(\"Mixed / Miješano\", money(d.mixedTotal || d.mixedRevenue))}\n          ${line(\"Returns / Povrati\", money(d.returnTotal))}\n          <div class=\"line grand\"><span>Total / Ukupno</span><strong>${money(d.grandTotal || d.totalSales)}</strong></div>\n        `;\n\n      case \"CASH_HANDOVER\":\n        return `\n          ${line(\"Cash revenue / Gotovinski promet\", money(d.cashRevenue))}\n          ${line(\"Cash handover / Predaja gotovine\", money(d.cashDepositTotal))}\n          ${line(\"Difference / Razlika\", money(d.difference))}\n          ${line(\"Received by / Preuzeo\", text(d.receivedBy))}\n        `;\n\n      case \"CASH_RECONCILIATION\":\n        return `\n          ${line(\"Expected cash / Očekivana gotovina\", money(d.expectedCash || d.cashRevenue))}\n          ${line(\"Counted cash / Prebrojana gotovina\", money(d.countedCash || d.cashDepositTotal))}\n          ${line(\"Deposit / Polog\", money(d.cashDepositTotal))}\n          ${line(\"Difference / Razlika\", money(d.difference))}\n          ${line(\"Card revenue / Kartice\", money(d.cardRevenue))}\n          ${line(\"Other revenue / Ostalo\", money(d.otherRevenue))}\n        `;\n\n      case \"PAYMENT_RECEIPT\":\n        return `\n          ${line(\"Payment number / Broj uplate\", text(d.paymentNumber))}\n          ${line(\"Partner / Partner\", text(d.partnerName))}\n          ${line(\"Payment method / Način plaćanja\", text(d.paymentMethod))}\n          ${line(\"Reference / Poziv na broj\", text(d.referenceNumber))}\n          <div class=\"line grand\"><span>Amount / Iznos</span><strong>${money(d.amount)} ${text(d.currencyCode || \"EUR\")}</strong></div>\n          ${line(\"Note / Napomena\", text(d.note))}\n        `;\n\n      case \"PAYMENT_CONFIRMATION\":\n        return `\n          ${line(\"Confirmation / Potvrda\", text(d.paymentNumber || d.referenceNumber))}\n          ${line(\"Paid by / Uplatio\", text(d.partnerName || d.payerName))}\n          ${line(\"Received by / Zaprimio\", text(d.cashier || d.username))}\n          <div class=\"line grand\"><span>Amount / Iznos</span><strong>${money(d.amount)} ${text(d.currencyCode || \"EUR\")}</strong></div>\n          ${line(\"Payment method / Način plaćanja\", text(d.paymentMethod))}\n        `;\n\n      case \"Z_REPORT\":\n        return `\n          ${line(\"Receipt count / Broj računa\", text(d.receiptCount))}\n          ${line(\"Cash / Gotovina\", money(d.cashTotal || d.cashRevenue))}\n          ${line(\"Card / Kartice\", money(d.cardTotal || d.cardRevenue))}\n          ${line(\"Other / Ostalo\", money(d.otherTotal || d.otherRevenue))}\n          ${line(\"Mixed / Miješano\", money(d.mixedTotal || d.mixedRevenue))}\n          ${line(\"Returns / Povrati\", money(d.returnTotal))}\n          <div class=\"line grand\"><span>Z Total / Z Ukupno</span><strong>${money(d.grandTotal || d.totalSales)}</strong></div>\n        `;\n\n      default:\n        return `\n          ${line(\"Total / Ukupno\", money(d.totalSales || d.grandTotal || d.amount))}\n        `;\n    }\n  }\n\n  function update(model) {\n    document.getElementById(\"report-root\").innerHTML = render(model || {});\n  }\n\n  update(window.appsmith?.model || {});\n\n  if (window.appsmith?.onModelChange) {\n    window.appsmith.onModelChange(update);\n  }\n</script>\n\n<style>\n  body {\n    margin: 0;\n    background: #f3f4f6;\n    color: #111827;\n    font-family: Arial, sans-serif;\n  }\n\n  .print-button {\n    display: block;\n    margin: 10px auto;\n    padding: 8px 14px;\n    background: #111827;\n    color: white;\n    border: none;\n    font-weight: 800;\n    cursor: pointer;\n  }\n\n  .report-page {\n    width: 80mm;\n    margin: 0 auto;\n    padding: 5mm;\n    background: white;\n    box-sizing: border-box;\n    font-size: 12px;\n    line-height: 1.35;\n  }\n\n  .header {\n    text-align: center;\n  }\n\n  .company-logo {\n    max-width: 52mm;\n    max-height: 22mm;\n    object-fit: contain;\n    display: block;\n    margin: 0 auto 6px auto;\n  }\n\n  .brand {\n    font-size: 17px;\n    font-weight: 900;\n    text-transform: uppercase;\n  }\n\n  .small {\n    font-size: 10px;\n    color: #374151;\n  }\n\n  .divider {\n    border-top: 1px dashed #111827;\n    margin: 9px 0;\n  }\n\n  .title {\n    text-align: center;\n    font-size: 14px;\n    font-weight: 900;\n    margin-bottom: 8px;\n    text-transform: uppercase;\n  }\n\n  .section-title {\n    font-weight: 900;\n    margin-bottom: 6px;\n  }\n\n  .line {\n    display: flex;\n    justify-content: space-between;\n    gap: 8px;\n    margin: 4px 0;\n  }\n\n  .grand {\n    background: #111827;\n    color: white;\n    padding: 8px;\n    margin: 8px 0;\n    font-size: 14px;\n    font-weight: 900;\n  }\n\n  .qr-box {\n    text-align: center;\n  }\n\n  .qr-small {\n    width: 88px;\n    height: 88px;\n  }\n\n  .signatures {\n    font-size: 10px;\n  }\n\n  .signature-line {\n    border-bottom: 1px solid #111827;\n    height: 22px;\n    margin-bottom: 10px;\n  }\n\n  @media print {\n    body {\n      background: white;\n    }\n\n    .print-button {\n      display: none;\n    }\n\n    .report-page {\n      width: 80mm;\n      margin: 0;\n      padding: 4mm;\n    }\n  }\n</style>\n",
